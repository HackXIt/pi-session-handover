{
  "name": "@hackxit/pi-session-handover",
  "version": "0.1.0",
  "description": "Pi extension for closing one agent turn and handing over to a new session",
  "keywords": [
    "pi-package",
    "pi-extension",
    "handover"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "README.md",
    "LICENSE",
    "docs",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package:check": "npm pack --dry-run",
    "ci": "npm test && npm run typecheck && npm run package:check"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
